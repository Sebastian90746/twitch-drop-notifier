# Games to monitor (exact names as shown on Twitch)
games:
  - "Rust"
  - "Path of Exile 2"
  - "World of Warcraft"

# How often to check for new campaigns (in minutes)
check_interval_minutes: 30

# Test mode: returns ALL games with active drops (ignores game filter),
# forces 1 minute interval, enables DEBUG logging, does not save state.
# Set to false or remove this line for normal operation.
test_mode: false

notifications:
  email:
    enabled: true
    smtp_host: "smtp.gmail.com"
    smtp_port: 587
    smtp_user: "you@gmail.com"
    smtp_password: "your_app_password"   # Gmail: create at myaccount.google.com/apppasswords
    from_address: "you@gmail.com"
    to_addresses:
      - "recipient@example.com"
